+// Live Court View — replaces the unworkable iframe of courtview2.allahabadhighcourt.in.
+// The court page sends X-Frame-Options: SAMEORIGIN, so iframe embedding is blocked by every browser.
+// Instead we fetch /api/court-view (which scrapes the same page server-side) and render natively.
+function LiveCourtViewPanel({ bench, externalUrl, refreshSignal }) {
+  const [data, setData] = useState(null);
+  const [loading, setLoading] = useState(false);
+  const [error, setError] = useState(null);
+  const [refreshedAt, setRefreshedAt] = useState(null);
+
+  useEffect(() => {
+    let alive = true;
+    let timer = null;
+    const load = async (showSpinner) => {
+      if (showSpinner) setLoading(true);
+      try {
+        const res = await CourtAPI.getCourtView(bench);
+        if (!alive) return;
+        setData(res);
+        setError(null);
+        setRefreshedAt(new Date());
+      } catch (e) {
+        if (!alive) return;
+        setError(e.message || 'Failed to fetch court view');
+      } finally {
+        if (alive) setLoading(false);
+      }
+    };
+    load(true);
+    timer = setInterval(() => load(false), 30000); // backend caches for 30s
+    return () => { alive = false; if (timer) clearInterval(timer); };
