+// Format an ISO date as "x hours ago" / "x days ago" for the news card.
+function relativeTime(iso) {
+  if (!iso) return '';
+  const t = Date.parse(iso);
+  if (isNaN(t)) return '';
+  const diff = Date.now() - t;
+  const min = Math.floor(diff / 60000);
+  if (min < 1) return 'just now';
+  if (min < 60) return `${min} min ago`;
+  const hr = Math.floor(min / 60);
+  if (hr < 24) return `${hr} hour${hr === 1 ? '' : 's'} ago`;
+  const d = Math.floor(hr / 24);
+  if (d < 30) return `${d} day${d === 1 ? '' : 's'} ago`;
+  const mo = Math.floor(d / 30);
+  if (mo < 12) return `${mo} month${mo === 1 ? '' : 's'} ago`;
+  return new Date(iso).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
+}
+
+// Module-level cache so dashboard + Legal Updates page share one network call.
+let _legalNewsCache = null;
+let _legalNewsPromise = null;
+function fetchLegalNewsOnce() {
+  if (_legalNewsCache) return Promise.resolve(_legalNewsCache);
+  if (_legalNewsPromise) return _legalNewsPromise;
+  _legalNewsPromise = CourtAPI.getNews(40)
+    .then(res => {
+      if (res && res.status === 'success' && Array.isArray(res.items)) {
+        _legalNewsCache = res.items.map(it => ({
+          id: it.id,
+          title: it.title,
+          desc: it.description || '',
+          time: relativeTime(it.pubDate) || (it.pubDateRaw || ''),
+          url: it.link || '#',
+          source: it.source, // 'headlines' | 'judgments'
+        }));
+        return _legalNewsCache;
+      }
+      return LEGAL_NEWS_FALLBACK;
+    })
+    .catch(() => LEGAL_NEWS_FALLBACK)
+    .finally(() => { _legalNewsPromise = null; });
+  return _legalNewsPromise;
+}
+
+// React hook for components that render legal news.
+function useLegalNews() {
+  const [items, setItems] = useState(_legalNewsCache || LEGAL_NEWS_FALLBACK);
+  const [loading, setLoading] = useState(!_legalNewsCache);
+  useEffect(() => {
+    let alive = true;
+    fetchLegalNewsOnce().then(list => {
+      if (!alive) return;
+      setItems(list);
+      setLoading(false);
+    });
+    return () => { alive = false; };
+  }, []);
+  return { items, loading };
+}
